# ZZZ Discord Bot — environment variables
# Either fill these in via your deploy host's secret manager (systemd EnvironmentFile / pm2 ecosystem.env / etc),
# OR drop a config.json in the project root with the same keys (legacy).
# Env wins when both exist.

# === REQUIRED ===
# Discord bot token (production)
TOKEN=

# === HIGHLY RECOMMENDED ===
TEST_TOKEN=
CMDWEBHOOK=
JLWEBHOOK=
LOGWEBHOOK=
FBWEBHOOK=
ERRWEBHOOK=
AUTHTOKEN=
WEBSERVER_PORT=3001
DEVIDS=111111111111111111,222222222222222222
# Public URL for the verification mini-site (CAPTCHA/geetest hub)
VERIFY_PUBLIC_URL=https://verify.yeci.lol/zzz
# External stats API (signal/checkin metrics)
STATS_API_URL=
STATS_API_TOKEN=

# === Plan A/B/C — web-login integration ===
# Public URL of the web-login Next.js app (Vercel deployment, no trailing slash)
WEB_LOGIN_URL=https://your-web-login.vercel.app
# Shared secret for web-login → bot webhook (Bearer auth)
WEBHOOK_SECRET=
# Port for the bot's webhook receiver HTTP server (default 3002)
WEBHOOK_PORT=3002
# Supabase project URL
SUPABASE_URL=
# Supabase service_role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=
# Cookie decryption key — MUST match SESSION_SECRET in web-login .env
WEB_LOGIN_SESSION_SECRET=

# === Optional — IP-block proxy for Hoyoverse login ===
PROXY_API_URL=
PROXY_API_TOKEN=
